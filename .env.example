# Produto (chat do app) — NÃO é key do coding agent.
#
# Smoke padrão (Windows / sistema) — preferido se já existir:
#   OPEN_ROUTER_API_KEY=...
# Opcional override local (apps/waifu-chat/.env.local):
OPEN_ROUTER_API_KEY=
OPENROUTER_API_KEY=

# Modelo barato (opcional)
# Preferidos smoke/custo: deepseek/deepseek-v4-flash | nvidia/nemotron-nano-9b-v2:free
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
# OPEN_ROUTER_MODEL=

# Optional: site URL for OpenRouter rankings
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=WaifuChat

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
